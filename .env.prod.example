# .env.prod.example - ResumeAI production environment template
#
# Usage:
#   cp .env.prod.example .env.prod
#   # Edit values below as needed (every line is OPTIONAL - defaults work)
#   docker compose up -d --build
#
# Every variable is OPTIONAL. The backend ships with sensible defaults in
# backend/app/config.py - leaving a line commented out just uses the default.
#
# BYOK (Bring Your Own Key) mode:
#   You can leave LLM_API_KEY empty and configure it later via the web UIs
#   Settings page. The web-UI value (stored encrypted in the SQLite DB)
#   takes priority over this env var. Convenient for demos where each
#   evaluator brings their own API key.

# === Application =========================================================
# MUST change in production. Used for session signing / encryption seed.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# SECRET_KEY=change-me-in-production

# Upload size limit (bytes). Default 20MB. If you raise this, also bump
# client_max_body_size in frontend/nginx.conf to match.
# MAX_FILE_SIZE=20971520

# Recruiter batch scoring concurrency (LLM provider rate-limit guard).
# Lower if you see 429s; bump up if your quota allows.
# BATCH_CONCURRENCY=5

# === LLM Provider ========================================================
# Defaults target Moonshot (Kimi). For other providers, set base_url +
# model_name accordingly. Anthropic / OpenAI / DeepSeek / Ollama all work.
#
# Examples:
#   Moonshot:  base_url=https://api.moonshot.cn/v1            model=moonshot-v1-32k
#   OpenAI:    base_url=https://api.openai.com/v1             model=gpt-4o-mini
#   DeepSeek:  base_url=https://api.deepseek.com/v1           model=deepseek-chat
#   Ollama:    base_url=http://host.docker.internal:11434/v1  model=qwen2.5

# LLM_PROVIDER_TYPE=openai_compatible      # ollama | openai_compatible | anthropic
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=                              # leave empty -> configure via web UI
# LLM_MODEL_NAME=moonshot-v1-32k
# LLM_TEMPERATURE=0.5

# === Database ============================================================
# SQLite path is relative to /app inside the backend container. The default
# points at the named volume mount /app/data/resume_assistant.db. Dont
# change this unless youre switching to a different DB engine (Postgres /
# MySQL would need additional backend changes too).
# DB_URL=sqlite+aiosqlite:///data/resume_assistant.db

# === Uvicorn =============================================================
# Workers > 1 requires an external DB (SQLite breaks under concurrent writes
# beyond a single worker). Keep at 1 for the default SQLite setup.
# UVICORN_WORKERS=1
# UVICORN_LOG_LEVEL=info                  # debug | info | warning | error
